// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Berita {
  id          String   @id @default(cuid())
  judul       String   // Sesuai input "Judul"
  tagline     String   // Sesuai input "Tagline"
  gambar      String   // Nama file atau URL gambar
  tanggal     DateTime @default(now()) // Sesuai input "Tanggal"
  keterangan  String   @db.Text // Sesuai input "Keterangan"
  kategori    String   // Untuk membedakan tab "KLINIK" atau "KARTINI"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("berita")
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String 

  @@map("admin")
}

model Layanan {
  id           String   @id @default(cuid())
  namaLayanan  String
  harga        String
  jadwal       String
  keterangan   String   @db.Text
  gambar       String?  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("layanan")
}

// --- MODEL BARU: STATISTIK REALTIME ---
model Statistic {
  id      Int @id @default(1)
  pasien  Int @default(1000)
  dokter  Int @default(5)
  relawan Int @default(50)
  mitra   Int @default(50)
  @@map("statistic")
}