// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Berita {
  id          String   @id @default(cuid())
  judul       String   // Sesuai input "Judul"
  tagline     String   // Sesuai input "Tagline"
  gambar      String   // Nama file atau URL gambar
  tanggal     DateTime @default(now()) // Sesuai input "Tanggal"
  keterangan  String   @db.Text // Sesuai input "Keterangan"
  kategori    String   // Untuk membedakan tab "KLINIK" atau "KARTINI"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("berita")
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String 

  @@map("admin")
}